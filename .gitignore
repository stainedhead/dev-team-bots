# Binaries and build output
bin/
boabot/boabot
boabotctl/boabotctl
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries and coverage
*.test
*.out
coverage.html

# Config files — defaults live next to the binary, never in git
config.yaml
config.json
config.toml
*.local.yaml
*.local.json
*.local.toml

# Bot template configs are tracked — they contain no secrets (AWS values injected by CDK)
!boabot-team/bots/*/config.yaml

# Secrets and environment
.env
.env.*
secrets.*
*.pem
*.key
*.p12

# Go workspace (if used locally)
go.work
go.work.sum

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# golangci-lint cache
.golangci-lint-cache/

# Temporary files
tmp/
temp/
team_coverage.html
